# Google Spreadsheet ID
SPREADSHEET_ID=your-spreadsheet-id-here

# Slack Signing Secret (optional but recommended)
SLACK_SIGNING_SECRET=your-slack-signing-secret-here

# Google Service Account Key (JSON format)
# This should be set as a secret in Cloudflare Workers
# Use: wrangler secret put GOOGLE_SERVICE_ACCOUNT_KEY
# Then paste the entire JSON key